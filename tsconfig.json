{
  "extends": "@ember/app-tsconfig",
  "compilerOptions": {
    "paths": {
      "table-viewer/tests/*": [
        "./tests/*"
      ],
      "table-viewer/*": [
        "./app/*"
      ],
      "*": [
        "./types/*"
      ]
    },
    "types": [
      "ember-source/types",
      "@glint/ember-tsc/types",
      "@embroider/core/virtual",
      "vite/client",
      "vitest/importMeta"
    ]
  },
}
