{
  "name": "table-viewer",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Load and parse a table from a markdown document and make it interactive",
  "repository": "https://github.com/NullVoxPopuli/rere-benchmark",
  "license": "MIT",
  "author": "NullVoxPopuli",
  "scripts": {
    "build": "vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "format": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test:vitest": "vitest run",
    "test:qunit": ""
  },
  "imports": {
    "#colors": "./app/colors.ts",
    "#utils": "./app/utils.ts",
    "#components/*": "./app/components/*",
    "#services/*": "./app/services/*",
    "#routes/*": "./app/routes/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "dependencies": {
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "culori": "^4.0.1",
    "ember-modifier": "^4.2.0",
    "ember-page-title": "^8.2.4",
    "ember-primitives": "^0.27.2",
    "ember-resolver": "^13.1.0",
    "ember-source": "~6.4.0-alpha.3",
    "lz-string": "^1.5.0",
    "marked": "^15.0.7",
    "reactiveweb": "^1.4.0",
    "tracked-built-ins": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/plugin-transform-runtime": "^7.26.9",
    "@babel/plugin-transform-typescript": "^7.26.8",
    "@babel/runtime": "^7.26.9",
    "@ember/optional-features": "^2.2.0",
    "@embroider/core": "4.0.0-alpha.6",
    "@embroider/macros": "1.17.0-alpha.5",
    "@embroider/vite": "1.0.0-alpha.6",
    "@glint/core": "1.4.1-unstable.34c4510",
    "@glint/environment-ember-loose": "1.4.1-unstable.34c4510",
    "@glint/environment-ember-template-imports": "1.4.1-unstable.34c4510",
    "@glint/template": "1.4.1-unstable.34c4510",
    "@rollup/plugin-babel": "^6.0.4",
    "@tsconfig/ember": "^3.0.9",
    "@types/culori": "^2.1.1",
    "babel-plugin-ember-template-compilation": "^2.3.0",
    "concurrently": "^9.1.2",
    "decorator-transforms": "^2.3.0",
    "ember-eslint": "^0.1.0",
    "ember-template-lint": "^6.1.0",
    "eslint": "^9.20.1",
    "prettier": "^3.5.1",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">= 22"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  },
  "pnpm": {
    "overrides": {
      "@embroider/macros": "1.17.0-alpha.5",
      "@glimmer/component": "^2.0.0",
      "@glimmer/validator": ">= 0.92.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "webpack"
      ]
    }
  }
}
