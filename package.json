{
  "name": "table-viewer",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for table-viewer goes here",
  "repository": "https://github.com/NullVoxPopuli/markdown-table-viewer",
  "license": "GPL-3.0",
  "author": "NullVoxPopuli",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "format": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test:vitest": "vitest run",
    "test:qunit": ""
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/runtime": "^7.26.7",
    "@ember/optional-features": "^3.0.0",
    "@embroider/compat": "^4.1.17",
    "@embroider/core": "^4.4.7",
    "@embroider/vite": "^1.7.2",
    "@glimmer/component": "^2.1.1",
    "@glint/ember-tsc": "^1.5.0",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.4.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/culori": "^2.1.1",
    "babel-plugin-ember-template-compilation": "^2.3.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.0",
    "ember-eslint": "^0.6.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.5",
    "tracked-built-ins": "^4.1.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">= 22"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  },
  "imports": {
    "#utils": "./app/utils.ts",
    "#components/*": "./app/components/*",
    "#services/*": "./app/services/*",
    "#routes/*": "./app/routes/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "pnpm": {
    "overrides": {
      "@glimmer/validator": ">= 0.92.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "webpack"
      ]
    }
  },
  "dependencies": {
    "@ember/app-tsconfig": "^2.0.0",
    "culori": "^4.0.2",
    "ember-primitives": "^0.57.0",
    "marked": "^18.0.3",
    "reactiveweb": "^1.9.1"
  }
}
